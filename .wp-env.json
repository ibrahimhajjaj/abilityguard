{
	"core": null,
	"phpVersion": "8.3",
	"port": 18888,
	"testsPort": 18889,
	"plugins": [],
	"mappings": {
		"wp-content/plugins/abilityguard-mcp": ".",
		"wp-content/plugins/mcp-adapter": "./tests/fixtures/mcp-adapter"
	},
	"lifecycleScripts": {
		"afterStart": "wp-env run cli wp plugin activate abilityguard-mcp && wp-env run tests-cli wp plugin activate abilityguard-mcp"
	},
	"config": {
		"WP_DEBUG": true,
		"WP_DEBUG_LOG": true,
		"SCRIPT_DEBUG": true
	},
	"env": {
		"tests": {
			"config": {
				"WP_DEBUG": true,
				"WP_DEBUG_LOG": true
			}
		}
	}
}
